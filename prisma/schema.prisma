// Prisma schema for production-ready features
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Using string fields for roles and statuses to simplify local SQLite usage

model User {
  id            String      @id @default(cuid())
  email         String?     @unique
  passwordHash  String
  firstName     String
  lastName      String?
  country       String?
  city          String?
  role          String      @default("NORMAL")
  coins         Int         @default(0)
  points        Int         @default(0)
  emailVerified Boolean     @default(false)
  verificationCode String?
  verificationExpires DateTime?
  createdAt     DateTime    @default(now())
  videos        Video[]
  comments      Comment[]
  likes         Like[]
  purchases     VideoPurchase[]
  governmentDownloads DownloadRequest[] @relation("GovDownloads")
}

model Video {
  id           String       @id @default(cuid())
  description  String?
  videoUrl     String
  thumbnailUrl String
  watermarkUrl String?
  duration     Int
  country      String
  city         String
  road         String
  incidentType String
  incidentDate DateTime
  views        Int          @default(0)
  likes        Int          @default(0)
  dislikes     Int          @default(0)
  commentsCount Int         @default(0)
  createdAt    DateTime     @default(now())
  userId       String
  user         User         @relation(fields: [userId], references: [id])
  status       String       @default("DRAFT_ADMIN")
  comments     Comment[]
  likesRelation Like[]
  purchases    VideoPurchase[]
  downloadRequests DownloadRequest[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Like {
  id      String @id @default(cuid())
  type    String
  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  @@unique([videoId, userId])
}

model City {
  id        String   @id @default(cuid())
  name      String
  country   String

  @@unique([name, country])
}

model Road {
  id        String   @id @default(cuid())
  name      String
  city      String
}

model VideoPurchase {
  id        String   @id @default(cuid())
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  pointsPaid Int     @default(500)
  createdAt DateTime @default(now())

  @@unique([videoId, userId])
}

model DownloadRequest {
  id                 String   @id @default(cuid())
  videoId            String
  video              Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  governmentUserId   String
  governmentUser     User     @relation("GovDownloads", fields: [governmentUserId], references: [id])
  status             String   @default("PENDING")
  requestedAt        DateTime @default(now())
  approvedAt         DateTime?

  @@index([videoId, governmentUserId])
}
